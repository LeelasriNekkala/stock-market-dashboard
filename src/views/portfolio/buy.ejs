<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Buy Stock</title>
    <link rel="stylesheet" href="/css/style.css" />
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        min-height: 100vh;

        /* ⭐ center everything */
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

        background: radial-gradient(circle at 20% 20%, #1e293b, #020617);
        color: white;
      }

      h2 {
        margin-bottom: 20px;
      }

      form {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(8px);
        padding: 25px;
        border-radius: 12px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
      }

      input,
      button {
        width: 100%;
        padding: 12px;
        margin-bottom: 15px;
        border-radius: 6px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        font-size: 16px;
      }

      input {
        background: rgba(255, 255, 255, 0.05);
        color: white;
      }

      input::placeholder {
        color: rgba(255, 255, 255, 0.6);
      }

      button {
        background-color: #22c55e;
        color: white;
        border: none;
        cursor: pointer;
        font-weight: bold;
      }

      button:hover {
        background-color: #16a34a;
      }

      a {
        margin-top: 15px;
        color: #cbd5e1;
        text-decoration: none;
      }

      a:hover {
        color: #22c55e;
      }
    </style>
  </head>
  <body>
    <h2>Buy Stock</h2>

    <form action="/buy" method="POST">
      <input
        type="text"
        name="symbol"
        placeholder="Stock Symbol (e.g., AAPL)"
        required
      />

      <input
        type="number"
        name="quantity"
        placeholder="Quantity"
        min="1"
        required
      />

      <input
        type="number"
        name="buyPrice"
        placeholder="Buy Price"
        min="0.01"
        step="0.01"
        required
      />

      <button type="submit">Buy Stock</button>
    </form>

    <a href="/dashboard">Back to Dashboard</a>
  </body>
</html>
